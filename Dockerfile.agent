# Dockerfile for XLStatus Agent
FROM rust:1.75 as builder

WORKDIR /app

# Copy workspace files
COPY Cargo.toml Cargo.lock ./
COPY crates ./crates
COPY proto ./proto

# Build the agent
RUN cargo build --release --bin xlstatus-agent

# Runtime stage
FROM debian:bookworm-slim

RUN apt-get update && apt-get install -y \
    ca-certificates \
    libssl3 \
    procps \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Copy binary from builder
COPY --from=builder /app/target/release/xlstatus-agent /usr/local/bin/

# Environment variables
ENV SERVER_URL=http://localhost:8080
ENV AGENT_NAME=agent-1
ENV RUST_LOG=info

CMD ["xlstatus-agent"]
