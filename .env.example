# Copy to .env before running docker compose on a remote host.
#
# For local development you can leave both variables unset.
# For remote Docker Compose deployment, use addresses reachable from the user's browser.

# Example: http://example.com:8080
XLSTATUS_PUBLIC_API_URL=

# Example: http://example.com:3000,http://localhost:3000,http://127.0.0.1:3000
XLSTATUS_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
